{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "crm.getmypermit.pl" }],
      "destination": "/crm/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
